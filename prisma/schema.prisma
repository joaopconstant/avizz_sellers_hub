// This is your Prisma schema file
// Fonte da verdade do banco — Avizz Hub

generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  head
  closer
  sdr
  operational
}

enum WorkLocation {
  office
  home
  day_off
}

enum PaymentMethod {
  pix
  card
  boleto
}

enum SaleOrigin {
  organic
  referral
  outbound
  advance
}

enum RevenueTier {
  small
  medium
  large
  enterprise
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Company {
  id         String   @id @default(cuid())
  name       String
  created_at DateTime @default(now())

  users          User[]
  products       Product[]
  gateways       Gateway[]
  goals          Goal[]
  individualGoals IndividualGoal[]
  dailyReports   DailyReport[]
  sales          Sale[]
  advances       Advance[]
}

model User {
  id         String   @id @default(cuid())
  company_id String
  name       String
  email      String   @unique
  role       UserRole
  avatar_url String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company         Company          @relation(fields: [company_id], references: [id])
  dailyReports    DailyReport[]
  salesAsCloser   Sale[]           @relation("CloserSales")
  salesAsSdr      Sale[]           @relation("SdrSales")
  advancesAsCloser Advance[]       @relation("CloserAdvances")
  advancesAsSdr   Advance[]        @relation("SdrAdvances")
  individualGoals IndividualGoal[]
  goalsCreated    Goal[]
  productAuditLogs ProductAuditLog[]
  goalAuditLogs   GoalAuditLog[]

  // NextAuth
  accounts Account[]
  sessions Session[]
}

model Product {
  id             String   @id @default(cuid())
  company_id     String
  name           String
  description    String?
  is_active      Boolean  @default(true)
  counts_as_sale Boolean  @default(true)
  is_primary     Boolean  @default(false)
  sort_order     Int      @default(0)
  created_at     DateTime @default(now())

  company   Company          @relation(fields: [company_id], references: [id])
  sales     Sale[]
  auditLogs ProductAuditLog[]
}

model ProductAuditLog {
  id              String   @id @default(cuid())
  product_id      String
  changed_by      String
  previous_values Json
  new_values      Json
  changed_at      DateTime @default(now())

  product    Product @relation(fields: [product_id], references: [id])
  changedBy  User    @relation(fields: [changed_by], references: [id])
}

model Gateway {
  id         String   @id @default(cuid())
  company_id String
  name       String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  company Company       @relation(fields: [company_id], references: [id])
  rates   GatewayRate[]
  sales   Sale[]
}

model GatewayRate {
  id           String  @id @default(cuid())
  gateway_id   String
  installments Int
  rate_percent Decimal @db.Decimal(6, 4)

  gateway Gateway @relation(fields: [gateway_id], references: [id])

  @@unique([gateway_id, installments])
}

model Goal {
  id         String   @id @default(cuid())
  company_id String
  month      DateTime // sempre dia 01
  cash_goal  Decimal  @db.Decimal(12, 2)
  sales_goal Int
  created_by String
  created_at DateTime @default(now())

  company         Company          @relation(fields: [company_id], references: [id])
  createdBy       User             @relation(fields: [created_by], references: [id])
  individualGoals IndividualGoal[]
  auditLogs       GoalAuditLog[]

  @@unique([company_id, month])
}

model GoalAuditLog {
  id                  String   @id @default(cuid())
  goal_id             String
  changed_by          String
  previous_cash       Decimal? @db.Decimal(12, 2)
  new_cash            Decimal? @db.Decimal(12, 2)
  previous_sales_goal Int?
  new_sales_goal      Int?
  reason              String?
  changed_at          DateTime @default(now())

  goal      Goal @relation(fields: [goal_id], references: [id])
  changedBy User @relation(fields: [changed_by], references: [id])
}

model IndividualGoal {
  id               String   @id @default(cuid())
  company_id       String
  user_id          String
  goal_id          String
  cash_goal        Decimal  @db.Decimal(12, 2)
  sales_goal       Int?     // null para SDR
  rate_answer      Decimal? @db.Decimal(5, 4)
  rate_schedule    Decimal? @db.Decimal(5, 4)
  rate_noshow_max  Decimal? @db.Decimal(5, 4)
  rate_close       Decimal? @db.Decimal(5, 4)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])
  goal    Goal    @relation(fields: [goal_id], references: [id])

  @@unique([user_id, goal_id])
}

model DailyReport {
  id            String       @id @default(cuid())
  company_id    String
  user_id       String
  report_date   DateTime     @db.Date
  work_location WorkLocation

  // Campos SDR
  calls_total         Int?
  calls_answered      Int?
  meetings_scheduled  Int?
  meetings_held       Int?
  crm_activities      Int?
  bot_conversations   Int?
  reschedulings       Int?

  // Campos Closer
  calls_done     Int?
  closer_no_shows Int?
  disqualified   Int?
  crm_updated    Boolean?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company   Company   @relation(fields: [company_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id])
  sales     Sale[]
  advances  Advance[]

  @@unique([user_id, report_date])
  @@index([user_id])
  @@index([report_date])
  @@index([company_id])
}

model Sale {
  id                  String        @id @default(cuid())
  company_id          String
  closer_id           String
  sdr_id              String?
  product_id          String
  report_id           String?
  client_name         String
  client_company      String
  client_revenue_tier RevenueTier
  contract_value      Decimal       @db.Decimal(12, 2)
  contract_months     Int
  payment_method      PaymentMethod
  gateway_id          String?
  installments        Int?
  down_payment        Decimal?      @db.Decimal(12, 2)
  cash_value          Decimal       @db.Decimal(12, 2)
  net_value           Decimal       @db.Decimal(12, 2)
  future_revenue      Decimal       @db.Decimal(12, 2)
  counts_as_sale      Boolean       // snapshot imutável do produto
  sale_origin         SaleOrigin
  is_recovered        Boolean       @default(false)
  sale_date           DateTime      @db.Date
  created_at          DateTime      @default(now())

  company  Company      @relation(fields: [company_id], references: [id])
  closer   User         @relation("CloserSales", fields: [closer_id], references: [id])
  sdr      User?        @relation("SdrSales", fields: [sdr_id], references: [id])
  product  Product      @relation(fields: [product_id], references: [id])
  report   DailyReport? @relation(fields: [report_id], references: [id])
  gateway  Gateway?     @relation(fields: [gateway_id], references: [id])
  advance  Advance?

  @@index([company_id])
  @@index([closer_id])
  @@index([sale_date])
}

model Advance {
  id               String   @id @default(cuid())
  company_id       String
  closer_id        String
  sdr_id           String?
  report_id        String?
  lead_name        String
  company_name     String
  estimated_value  Decimal  @db.Decimal(12, 2)
  deadline         DateTime?
  lead_score       Int      @default(0)
  status_flags     String[]
  is_converted     Boolean  @default(false)
  converted_sale_id String? @unique
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  company       Company      @relation(fields: [company_id], references: [id])
  closer        User         @relation("CloserAdvances", fields: [closer_id], references: [id])
  sdr           User?        @relation("SdrAdvances", fields: [sdr_id], references: [id])
  report        DailyReport? @relation(fields: [report_id], references: [id])
  convertedSale Sale?        @relation(fields: [converted_sale_id], references: [id])
}

// ─── NextAuth.js v5 ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}
